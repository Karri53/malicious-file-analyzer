# AWS Credentials
AWS_ACCESS_KEY_ID=your_key_here
AWS_SECRET_ACCESS_KEY=your_secret_here
AWS_REGION=us-east-1

# S3 Buckets
S3_UPLOAD_BUCKET=malware-analyzer-uploads-temp
S3_EMAIL_BUCKET=malware-analyzer-emails
S3_RESULTS_BUCKET=malware-analyzer-results

# Snowflake Credentials
SNOWFLAKE_ACCOUNT=your_account.us-east-1
SNOWFLAKE_USER=your_username
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=MALWARE_ANALYZER_DB
SNOWFLAKE_SCHEMA=ANALYSIS_DATA

# Email Settings
SES_EMAIL_SOURCE=analyze@your-domain.com
SES_REGION=us-east-1

# Application Settings
FLASK_ENV=development
FLASK_PORT=5000
MAX_FILE_SIZE_MB=50